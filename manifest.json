{
  "manifest_version": 3,
  "name": "Tabbit",
  "description": "Organize Chrome tabs into native tab groups, close exact duplicates, and save tab sessions.",
  "version": "0.1.0",
  "minimum_chrome_version": "90",
  "permissions": ["tabs", "tabGroups", "storage"],
  "host_permissions": ["https://api.openai.com/*"],
  "icons": {
    "16": "icons/icon-light-16.png",
    "32": "icons/icon-light-32.png",
    "48": "icons/icon-light-48.png",
    "128": "icons/icon-light-128.png"
  },
  "action": {
    "default_title": "Tabbit",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon-light-16.png",
      "32": "icons/icon-light-32.png",
      "48": "icons/icon-light-48.png",
      "128": "icons/icon-light-128.png"
    },
    "theme_icons": [
      { "light": "icons/icon-light-16.png", "dark": "icons/icon-dark-16.png", "size": 16 },
      { "light": "icons/icon-light-32.png", "dark": "icons/icon-dark-32.png", "size": 32 },
      { "light": "icons/icon-light-48.png", "dark": "icons/icon-dark-48.png", "size": 48 },
      { "light": "icons/icon-light-128.png", "dark": "icons/icon-dark-128.png", "size": 128 }
    ]
  }
}
